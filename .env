# Copy file ini ke .env lalu isi nilainya
# cp .env.example .env

AIRFLOW_UID=50000

# ETL PostgreSQL
ETL_POSTGRES_USER=etl
ETL_POSTGRES_PASSWORD=your_password_here
ETL_POSTGRES_DB=etl_db
ETL_POSTGRES_HOST=localhost
ETL_POSTGRES_PORT=5433

# Airflow (opsional, default sudah ada di docker-compose)
# FERNET_KEY=your_fernet_key_here
# AIRFLOW__API_AUTH__JWT_SECRET=your_jwt_secret_here
